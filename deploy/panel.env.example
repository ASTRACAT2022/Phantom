APP_NAME="Phantom Control Plane"
DATABASE_URL=""
DATABASE_PATH="/var/lib/phantom-control-plane/panel.db"
FPTN_CONFIG_DIR="/var/lib/phantom-control-plane/fptn-config"
FPTN_SERVICE_NAME="ASTRACAT.Network"
FPTN_PROMETHEUS_METRICS_URL=""
FPTN_PROMETHEUS_INSECURE_TLS="false"
NODE_CONTROLLER_SHARED_TOKEN="replace-me-node-token"
BILLING_API_TOKEN="replace-me-billing-token"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-me-admin-password"
ADMIN_SESSION_SECRET="replace-me-admin-session-secret"
SESSION_COOKIE_SECURE="false"
PANEL_PUBLIC_BASE_URL=""
FORWARDED_ALLOW_IPS="127.0.0.1"
NODE_AGENT_GRPC_ENABLED="false"
NODE_AGENT_GRPC_HOST="0.0.0.0"
NODE_AGENT_GRPC_PORT="50061"
PHANTOM_SEED_DEMO="false"
PANEL_TIMEZONE="Europe/Moscow"
PANEL_HOST="0.0.0.0"
PANEL_PORT="8000"
PHANTOM_BACKUP_DIR="/var/backups/phantom-control-plane"
PHANTOM_BACKUP_RETENTION_DAYS="14"
