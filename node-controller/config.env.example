# Admin panel URL
PHANTOM_PANEL_URL=http://127.0.0.1:8000

# Must match NODE_CONTROLLER_SHARED_TOKEN on the panel
PHANTOM_SHARED_TOKEN=phantom-node-shared-token

# Transport between node and panel: http or grpc
PHANTOM_NODE_TRANSPORT=http

# Optional when PHANTOM_NODE_TRANSPORT=grpc
PHANTOM_PANEL_GRPC_TARGET=
PHANTOM_PANEL_GRPC_PORT=50061

# Stable node agent identity
PHANTOM_AGENT_ID=edge-ams-01

# Node metadata shown in the panel and embedded into FPTN server list.
# Leave host/port/tier/region empty if you want the agent to fetch defaults from panel.
FPTN_NODE_NAME=Edge AMS-01
FPTN_NODE_HOST=
FPTN_NODE_PORT=
FPTN_NODE_REGION=
FPTN_NODE_TIER=

# Optional: certificate path to auto-calculate md5_fingerprint
FPTN_CERT_PATH=/etc/fptn/server.crt

# Optional: FPTN config dir for users.list self-check
FPTN_CONFIG_DIR=/etc/fptn

# Optional: local FPTN metrics endpoint for exact active sessions
LOCAL_FPTN_METRICS_URL=http://127.0.0.1:8080/api/v1/metrics/secret

# Optional: network interface for traffic counters. Leave empty for auto-detect.
PHANTOM_NET_INTERFACE=

# Heartbeat tuning
PHANTOM_HEARTBEAT_INTERVAL=30
PHANTOM_FPTN_SYNC_INTERVAL=5
PHANTOM_REQUEST_TIMEOUT=5
