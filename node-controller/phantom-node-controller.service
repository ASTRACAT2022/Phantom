[Unit]
Description=Phantom Node Controller for FPTN
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/phantom-node-controller.env
ExecStart=/usr/bin/python3 /opt/phantom-node-controller/agent.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
